SOLO_TRIAL_LICENSE_KEY=
AGENTGATEWAY_LICENSE=
ENTERPRISE_AGW_VERSION=2.2.0

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""


# Note
# To get these, run (match thhis to your environment):
# ❯ aws sts assume-role \
#  --profile default \
#  --role-arn arn:aws:iam::<account-id>:role/bedrock-agentgateway-role \
#  --role-session-name agentgateway-lab \
#  --duration-seconds 3600 \
#  --query "Credentials.[AccessKeyId,SecretAccessKey,SessionToken]" \
#  --output text

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# Auth0 OAuth (for MCP OIDC ExtAuth)
AUTH0_CLIENT_SECRET=""

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Used for Agent gateway UI
KEYCLOAK_BACKEND_CLIENT_SECRET=
KEYCLOAK_USER_PASSWORD

# Microsoft Entra tenant ID (UUID)
ENTRA_TENANT_ID=

# Microsoft Entra OBO (see enterprise/resources/msft-obo/README.md)
# Example: middle-tier app client ID (token aud = api://this-value)
# ENTRA_MIDDLETIER_CLIENT_ID=ec791040-80f8-4129-bf34-96a0e0672c96
ENTRA_MIDDLETIER_CLIENT_ID=
# Example: downstream API scope (e.g. api://<downstream-app-id>/.default)
# ENTRA_DOWNSTREAM_SCOPE=api://9beda151-9370-42f2-a2f7-17933c5c5a7c/.default
ENTRA_DOWNSTREAM_SCOPE=
# Middle-tier app client secret (value only; never commit real secrets)
ENTRA_OBO_CLIENT_SECRET=

FIGMA_OAUTH_CLIENT_ID=
FIGMA_OAUTH_CLIENT_SECRET=
FIGMA_REDIRECT_URI=

DATABRICKS_OAUTH_CLIENT_ID=
DATABRICKS_OAUTH_CLIENT_SECRET=